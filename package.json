{
  "name": "tree-sitter-tonel-smalltalk",
  "version": "0.2.2",
  "description": "Tree-sitter grammar for Tonel-exported Smalltalk source files",
  "type": "module",
  "main": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "keywords": [
    "tree-sitter",
    "smalltalk",
    "tonel",
    "parser"
  ],
  "license": "MIT",
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.26.8"
  },
  "tree-sitter": [
    {
      "scope": "source.smalltalk",
      "file-types": [
        "st"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}